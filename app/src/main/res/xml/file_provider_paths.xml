<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        Grants the system camera app access to write photos into the app's
        external pictures directory (getExternalFilesDir(Environment.DIRECTORY_PICTURES)).
        This does NOT require WRITE_EXTERNAL_STORAGE on Android 10+.
    -->
    <external-files-path
        name="brain_scan_images"
        path="Pictures/"/>
</paths>
