<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/welcomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_primary"
    android:fitsSystemWindows="true">

    <!-- Decorative circle top-right -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="#14FFFFFF"/>

    <!-- Decorative circle bottom-left -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="#0FFFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <!-- Logo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/welcomeLogoCard"
                android:layout_width="160dp"
                android:layout_height="160dp"
                app:cardCornerRadius="80dp"
                app:cardElevation="24dp"
                app:cardBackgroundColor="#FFFFFF"
                android:alpha="0"
                android:layout_marginBottom="32dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="28dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Title -->
            <TextView
                android:id="@+id/welcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_doctor"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:alpha="0"
                android:layout_marginBottom="12dp"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/welcomeSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/welcome_subtitle"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="#FFFFFF"
                android:alpha="0"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="40dp"/>

            <!-- Feature Cards Row -->
            <LinearLayout
                android:id="@+id/featureCardsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="40dp"
                android:alpha="0">

                <!-- Feature: AI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="#26FFFFFF"
                    android:padding="16dp"
                    android:layout_marginEnd="10dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_brain"
                        app:tint="@color/white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_ai"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Feature: Real-time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="#26FFFFFF"
                    android:padding="16dp"
                    android:layout_marginEnd="10dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_flash"
                        app:tint="@color/white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_realtime"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Feature: Secure -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="#26FFFFFF"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_secure"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CTA Button -->
            <Button
                android:id="@+id/goToDashboardButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/action_go_to_dashboard"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:backgroundTint="@color/white"
                app:cornerRadius="30dp"
                android:alpha="0"
                android:elevation="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- Skip / Tour text -->
            <TextView
                android:id="@+id/skipText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_take_tour"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0"
                android:padding="8dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>