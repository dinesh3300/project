<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_primary">

    <!-- Outer pulse ring -->
    <View
        android:id="@+id/pulseRing1"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:background="@drawable/circle_background"
        android:backgroundTint="#26FFFFFF"
        android:alpha="0"/>

    <!-- Middle pulse ring -->
    <View
        android:id="@+id/pulseRing2"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:background="@drawable/circle_background"
        android:backgroundTint="#33FFFFFF"
        android:alpha="0"/>

    <!-- Central Content -->
    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logoCard"
            android:layout_width="180dp"
            android:layout_height="180dp"
            app:cardCornerRadius="90dp"
            app:cardElevation="32dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="32dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- App Name -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineLarge"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:letterSpacing="0.08"
            android:alpha="0"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_power"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:alpha="0"
            android:layout_marginTop="8dp"/>

        <!-- Version badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/versionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#26FFFFFF"
            android:layout_marginTop="16dp"
            android:alpha="0">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/splash_version"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Bottom loading section -->
    <LinearLayout
        android:id="@+id/loadingSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="60dp"
        android:paddingHorizontal="48dp"
        android:alpha="0">

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_init"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:alpha="0.8"
            android:layout_marginBottom="12dp"/>

        <!-- Thin loading bar -->
        <ProgressBar
            android:id="@+id/loadingBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:progressTint="@color/white"
            android:indeterminateTint="@color/white"
            android:progressBackgroundTint="#40FFFFFF"/>
    </LinearLayout>

</FrameLayout>